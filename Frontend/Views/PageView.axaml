<UserControl
    x:Class="ClearText.Views.PageView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:ClearText.ViewModels"
    x:DataType="vm:PageViewModel">

    <Border Background="{DynamicResource DefaultFillBrush}" PointerPressed="OnPageClicked">
        <Grid Background="{DynamicResource DefaultBrightForegroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="4*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Rectangle Grid.Row="0" Fill="White" />

            <Grid Grid.Row="1" Background="Gray">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="8,0" />

                <!-- Meatball menu button -->
                <Button Grid.Column="1"
                        Content="⋮"
                        FontSize="18"
                        Background="Transparent"
                        BorderThickness="0"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0">
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <StackPanel>
                                <Button Command="{Binding RenameCommand}" Content="Rename" />
                                <Button Command="{Binding DeleteCommand}" Content="Delete" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>